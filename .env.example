# Porta pública da interface web
ROSITA_WEB_PORT=18080

# Porta pública da API
ROSITA_API_PORT=18500

# Endereço do servidor de IA/Ollama.
# Padrão: usa o Ollama interno do docker-compose.
# Se preferir um servidor externo/manual, troque a linha abaixo.
# Exemplo externo: ROSITA_OLLAMA_HOST=https://seu-servidor-ia.exemplo.com
ROSITA_OLLAMA_HOST=http://ollama:11434

# Modelo padrão do agente
ROSITA_OLLAMA_MODEL=llama3.2:3b

# GPU NVIDIA para o Ollama interno
# Use "all" para liberar todas as GPUs ou um índice, como "0"
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Ajustes opcionais
ROSITA_MAX_HISTORY=5
ROSITA_MAX_INPUT_CHARS=1000
ROSITA_NUM_PREDICT=128
ROSITA_TEMPERATURE=0.7
ROSITA_TOP_P=0.9
ROSITA_REPEAT_PENALTY=1.1
ROSITA_DEBUG=false
